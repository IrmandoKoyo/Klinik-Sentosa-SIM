{
  "rewrites": [
    {
      "source": "/sadclass/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/sadclass/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/sadclass",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}